<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Helmet Haven — Reset Password</title>

  <!-- Bootstrap 5 -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet"/>
  <!-- Google Fonts -->
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet"/>
  <!-- Bootstrap Icons -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet"/>

  <style>
    :root {
      --bg-dark:   #0d1219;
      --bg-card:   #131a24;
      --bg-input:  #1a2232;
      --accent:    #1d7fea;
      --border:    #1e2d3e;
      --text-muted:#4a5f75;
      --text-body: #8fa3b8;
      --text-white:#eef2f7;
    }

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      background: var(--bg-dark);
      font-family: 'Inter', sans-serif;
      color: var(--text-body);
      min-height: 100vh;
      display: flex;
      flex-direction: column;
    }

    /* ── NAVBAR ── */
    .hh-nav {
      background: var(--bg-dark);
      border-bottom: 1px solid var(--border);
      padding: 0.75rem 1.5rem;
      display: flex;
      align-items: center;
      gap: 0.6rem;
    }
    .brand-icon {
      width: 34px; height: 34px;
      background: var(--accent);
      border-radius: 50%;
      display: flex; align-items: center; justify-content: center;
      flex-shrink: 0;
    }
    .brand-name {
      font-size: 0.95rem;
      font-weight: 600;
      color: var(--text-white);
    }

    /* ── MAIN ── */
    .hh-main {
      flex: 1;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      padding: 3rem 1rem 2rem;
    }

    /* ── ICON CIRCLE ── */
    .page-icon-wrap {
      width: 56px; height: 56px;
      background: #182030;
      border-radius: 50%;
      display: flex; align-items: center; justify-content: center;
      margin: 0 auto 1.5rem;
    }

    /* ── HEADING ── */
    .page-title {
      font-size: 1.9rem;
      font-weight: 700;
      color: var(--text-white);
      text-align: center;
      margin-bottom: 0.55rem;
      letter-spacing: -0.01em;
    }
    .page-sub {
      font-size: 0.875rem;
      color: var(--text-muted);
      text-align: center;
      margin-bottom: 2rem;
    }

    /* ── CARD ── */
    .rp-card {
      background: var(--bg-card);
      border: 1px solid var(--border);
      border-radius: 14px;
      padding: 2rem 2rem 1.8rem;
      width: 100%;
      max-width: 420px;
    }

    /* ── FORM ── */
    .form-label {
      font-size: 0.875rem;
      font-weight: 500;
      color: var(--text-body);
      display: block;
      margin-bottom: 0.45rem;
    }
    .input-wrap {
      position: relative;
      margin-bottom: 1.2rem;
    }
    .input-icon {
      position: absolute;
      left: 0.95rem;
      top: 50%;
      transform: translateY(-50%);
      color: #3d5068;
      font-size: 1rem;
      pointer-events: none;
    }
    .hh-input {
      width: 100%;
      background: var(--bg-input);
      border: 1px solid var(--border);
      border-radius: 9px;
      color: var(--text-white);
      font-family: 'Inter', sans-serif;
      font-size: 0.9rem;
      padding: 0.8rem 0.9rem 0.8rem 2.6rem;
      outline: none;
      transition: border-color .2s, box-shadow .2s;
    }
    .hh-input::placeholder { color: transparent; }
    .hh-input:focus {
      border-color: var(--accent);
      box-shadow: 0 0 0 3px rgba(29,127,234,.15);
    }

    /* ── UPDATE BUTTON ── */
    .btn-update {
      background: var(--accent);
      border: none;
      border-radius: 9px;
      color: #fff;
      font-family: 'Inter', sans-serif;
      font-size: 0.95rem;
      font-weight: 600;
      padding: 0.82rem;
      width: 100%;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 0.45rem;
      transition: background .2s, transform .15s;
      cursor: pointer;
      margin-bottom: 1.6rem;
    }
    .btn-update:hover { background: #1568c9; transform: translateY(-1px); }
    .btn-update:active { transform: translateY(0); }

    /* ── DIVIDER ── */
    .divider {
      height: 1px;
      background: var(--border);
      margin-bottom: 1.2rem;
    }

    /* ── HELP TEXT ── */
    .help-text {
      text-align: center;
      font-size: 0.84rem;
      color: var(--text-muted);
    }
    .help-text a {
      color: var(--accent);
      text-decoration: none;
      font-weight: 500;
    }
    .help-text a:hover { text-decoration: underline; }

    /* ── BACK TO LOGIN ── */
    .back-wrap {
      text-align: center;
      margin-top: 1.8rem;
    }
    .back-link {
      font-size: 0.875rem;
      color: var(--text-muted);
      text-decoration: none;
      display: inline-flex;
      align-items: center;
      gap: 0.35rem;
      transition: color .2s;
    }
    .back-link:hover { color: var(--text-white); }

    /* ── FOOTER ── */
    .hh-footer {
      border-top: 1px solid var(--border);
      padding: 1.1rem 2rem;
      display: flex;
      align-items: center;
      justify-content: space-between;
      flex-wrap: wrap;
      gap: 0.5rem;
    }
    .foot-copy {
      font-size: 0.7rem;
      font-weight: 600;
      letter-spacing: 0.07em;
      text-transform: uppercase;
      color: var(--text-muted);
    }
    .foot-links {
      display: flex;
      gap: 1.5rem;
    }
    .foot-links a {
      font-size: 0.7rem;
      font-weight: 600;
      letter-spacing: 0.07em;
      text-transform: uppercase;
      color: var(--text-muted);
      text-decoration: none;
      transition: color .2s;
    }
    .foot-links a:hover { color: var(--text-white); }
  </style>
</head>
<body>

  <!-- NAVBAR -->
  <nav class="hh-nav">
    <div class="brand-icon">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="white" xmlns="http://www.w3.org/2000/svg">
        <path d="M12 2C8.5 2 5.5 4.5 5 8H4a2 2 0 0 0-2 2v1a2 2 0 0 0 2 2h.27A7 7 0 0 0 12 18a7 7 0 0 0 7.73-5H20a2 2 0 0 0 2-2v-1a2 2 0 0 0-2-2h-1C18.5 4.5 15.5 2 12 2zm0 2c2.76 0 5 2.24 5 5H7c0-2.76 2.24-5 5-5zm-7 7h14v1a5 5 0 0 1-10 0H5v-1z"/>
      </svg>
    </div>
    <span class="brand-name">Helmet Haven</span>
  </nav>

  <!-- MAIN -->
  <main class="hh-main">

    <!-- Page icon -->
    <div class="page-icon-wrap">
      <svg width="28" height="28" viewBox="0 0 28 28" fill="none" xmlns="http://www.w3.org/2000/svg">
        <!-- lock shackle -->
        <path d="M9 13V9.5C9 6.46 18.5 6.46 18.5 9.5V13" stroke="#1d7fea" stroke-width="1.6" stroke-linecap="round" fill="none"/>
        <!-- lock body -->
        <rect x="6.5" y="13" width="12" height="9" rx="2" stroke="#1d7fea" stroke-width="1.6" fill="rgba(29,127,234,0.15)"/>
        <!-- keyhole -->
        <circle cx="12.5" cy="17" r="1.2" fill="#1d7fea"/>
        <rect x="11.8" y="17" width="1.4" height="2" rx="0.7" fill="#1d7fea"/>
        <!-- refresh arrow -->
        <path d="M20 5.5 C23 5.5 25.5 8 25.5 11 C25.5 14 23 16.5 20 16.5" stroke="#1d7fea" stroke-width="1.6" stroke-linecap="round" fill="none"/>
        <polyline points="18,3.5 20,5.5 18,7.5" fill="none" stroke="#1d7fea" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </div>

    <!-- Title -->
    <h1 class="page-title">Reset Password</h1>
    <p class="page-sub">Please enter your new security credentials below.</p>

    <!-- Card -->
    <div class="rp-card">
      <form novalidate>

        <!-- New Password -->
        <label class="form-label">New Password</label>
        <div class="input-wrap">
          <i class="bi bi-lock input-icon"></i>
          <input type="password" class="hh-input" placeholder="••••••••"/>
        </div>

        <!-- Confirm New Password -->
        <label class="form-label">Confirm New Password</label>
        <div class="input-wrap">
          <i class="bi bi-shield-lock input-icon"></i>
          <input type="password" class="hh-input" placeholder="••••••••"/>
        </div>

        <!-- Update Button -->
        <button type="submit" class="btn-update">
          Update Password <i class="bi bi-arrow-right"></i>
        </button>

      </form>

      <!-- Divider -->
      <div class="divider"></div>

      <!-- Help -->
      <p class="help-text">Need help? <a href="#">Contact Security Support</a></p>
    </div>

    <!-- Back to login -->
    <div class="back-wrap">
      <a href="#" class="back-link">
        <i class="bi bi-arrow-left"></i> Back to login
      </a>
    </div>

  </main>

  <!-- FOOTER -->
  <footer class="hh-footer">
    <span class="foot-copy">© 2024 Helmet Haven Inc.</span>
    <nav class="foot-links">
      <a href="#">Privacy Policy</a>
      <a href="#">Terms of Service</a>
      <a href="#">Global Standards</a>
    </nav>
  </footer>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>