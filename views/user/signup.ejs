<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Sign Up | Helmet Haven</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">

    <style>
        :root {
            --bg-dark: #070b11;
            --card-bg: #111821;
            --accent-blue: #007bff;
            --text-muted: #8b949e;
            --border-color: #21262d;
        }

        body {
            background-color: var(--bg-dark);
            color: white;
            font-family: 'Plus Jakarta Sans', sans-serif;
            min-height: 100vh;
            display: flex;
            flex-direction: column;
        }

        /* Top Navbar */
        .top-nav {
            padding: 20px 5%;
            font-weight: 700;
            color: white;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        /* Main Content Grid */
        .main-wrapper {
            flex: 1;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 40px 5%;
        }

        /* Left Content Styling */
        .info-section {
            padding-right: 50px;
        }

        .tagline {
            color: var(--accent-blue);
            font-size: 0.8rem;
            font-weight: 700;
            letter-spacing: 1.5px;
            text-transform: uppercase;
        }

        .main-title {
            font-size: 4rem;
            font-weight: 800;
            line-height: 1.1;
            margin: 20px 0;
        }

        .benefit-item {
            display: flex;
            align-items: center;
            gap: 15px;
            margin-bottom: 25px;
            color: #c9d1d9;
        }

        .benefit-icon {
            width: 40px;
            height: 40px;
            background: rgba(0, 123, 255, 0.1);
            border-radius: 8px;
            display: flex;
            align-items: center;
            justify-content: center;
            color: var(--accent-blue);
        }

        /* Right Card Styling */
        .signup-card {
            background-color: var(--card-bg);
            border: 1px solid var(--border-color);
            border-radius: 24px;
            padding: 40px;
            width: 100%;
            max-width: 550px;
            box-shadow: 0 20px 40px rgba(0,0,0,0.4);
        }

        .form-label {
            font-size: 0.85rem;
            font-weight: 600;
            color: #c9d1d9;
            margin-bottom: 8px;
        }

        .form-control {
            background-color: #0d1117;
            border: 1px solid var(--border-color);
            color: white;
            padding: 12px 15px;
            border-radius: 8px;
        }

        .form-control:focus {
            background-color: #0d1117;
            border-color: var(--accent-blue);
            box-shadow: none;
            color: white;
        }

        .hint-text {
            font-size: 0.7rem;
            color: #586069;
            margin-top: 5px;
        }

        .btn-create {
            background-color: var(--accent-blue);
            border: none;
            padding: 14px;
            font-weight: 700;
            border-radius: 12px;
            margin-top: 20px;
        }

        .btn-google {
            background: transparent;
            border: 1px solid var(--border-color);
            color: white;
            padding: 12px;
            border-radius: 12px;
            font-weight: 600;
        }

        .divider {
            display: flex;
            align-items: center;
            text-align: center;
            margin: 30px 0;
            color: #586069;
            font-size: 0.7rem;
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        .divider::before, .divider::after {
            content: '';
            flex: 1;
            border-bottom: 1px solid var(--border-color);
        }

        .divider:not(:empty)::before { margin-right: 1.5em; }
        .divider:not(:empty)::after { margin-left: 1.5em; }

        /* Footer */
        .footer-bar {
            padding: 30px 5%;
            border-top: 1px solid var(--border-color);
            display: flex;
            justify-content: space-between;
            align-items: center;
            font-size: 0.8rem;
            color: #586069;
        }

        .footer-links a {
            color: #586069;
            text-decoration: none;
            margin-left: 20px;
        }

        /* Mobile Adjustments */
        @media (max-width: 991px) {
            .info-section { display: none; }
            .signup-card { margin: 0 auto; }
        }
    </style>
</head>
<body>

    <header class="top-nav">
        <i class="bi bi-shield-shaded text-primary"></i> HELMET HAVEN
    </header>

    <main class="main-wrapper">
        <div class="container">
            <div class="row align-items-center">
                
                <div class="col-lg-6 info-section">
                    <span class="tagline">Join the Elite</span>
                    <h1 class="main-title">Gear Up for<br>Your Next Ride</h1>
                    <p class="text-muted mb-5" style="max-width: 450px;">
                        Create an account to access exclusive releases, personalized safety recommendations, and a seamless checkout experience.
                    </p>

                    <div class="benefit-item">
                        <div class="benefit-icon"><i class="bi bi-patch-check"></i></div>
                        <span>Verified Safety Standards</span>
                    </div>
                    <div class="benefit-item">
                        <div class="benefit-icon"><i class="bi bi-truck"></i></div>
                        <span>Priority Shipping on All Orders</span>
                    </div>
                    <div class="benefit-item">
                        <div class="benefit-icon"><i class="bi bi-gift"></i></div>
                        <span>Early Access to New Collections</span>
                    </div>
                </div>

                <div class="col-lg-6">
                    <div class="signup-card">
                        <h2 class="fw-bold mb-1">Create Account</h2>
                        <p class="text-muted mb-4 small">Enter your details to create your Helmet Haven profile.</p>

                       <form action="/auth/signup" method="POST">

    <% if (typeof message !== 'undefined') { %>
        <div class="alert alert-danger"><%= message %></div>
    <% } %>
                            <div class="row">
                                <div class="col-md-6 mb-3">
                                    <label class="form-label">First Name</label>
                                    <input type="text" class="form-control">
                                </div>
                                <div class="col-md-6 mb-3">
                                    <label class="form-label">Last Name</label>
                                    <input type="text" class="form-control">
                                </div>
                            </div>

                            <div class="mb-3">
                                <label class="form-label">Email Address</label>
                                <input type="email" class="form-control">
                            </div>

                            <div class="mb-3">
                                <label class="form-label">Password</label>
                                <input type="password" class="form-control">
                                <div class="hint-text">Must be at least 8 characters with a symbol.</div>
                            </div>

                            <div class="mb-3">
                                <label class="form-label">Confirm Password</label>
                                <input type="password" class="form-control">
                            </div>

                            <div class="mb-4">
                                <label class="form-label">Referral Code (Optional)</label>
                                <input type="text" class="form-control" placeholder="Enter code">
                            </div>

                            <div class="form-check mb-4 small">
                                <input class="form-check-input" type="checkbox" id="terms">
                                <label class="form-check-label text-muted" for="terms">
                                    I agree to the <a href="#" class="text-primary text-decoration-none">Terms of Service</a> and <a href="#" class="text-primary text-decoration-none">Privacy Policy</a>.
                                </label>
                            </div>

                            <button class="btn btn-primary w-100 btn-create">Create Account</button>

                            <div class="divider">Or sign up with</div>

                            <button type="button" class="btn btn-google w-100 d-flex align-items-center justify-content-center gap-2">
                                <i class="bi bi-google"></i> Google
                            </button>

                            <p class="text-center mt-4 small text-muted">
                                Already have an account? <a href="#" class="text-primary text-decoration-none fw-bold">Log In</a>
                            </p>
                        </form>
                    </div>
                </div>

            </div>
        </div>
    </main>

    <footer class="footer-bar">
        <div>&copy; 2026 Helmet Haven. Professional grade protection for every rider.</div>
        <div class="footer-links">
            <a href="#">Privacy Policy</a>
            <a href="#">Safety Standards</a>
            <a href="#">Support</a>
        </div>
    </footer>

</body>
</html>