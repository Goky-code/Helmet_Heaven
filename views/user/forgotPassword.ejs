<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Helmet Haven — Forgot Password</title>

  <!-- Bootstrap 5 -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet"/>
  <!-- Google Fonts -->
  <link href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@700;800&family=Barlow:wght@300;400;500;600&display=swap" rel="stylesheet"/>
  <!-- Bootstrap Icons -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet"/>

  <style>
    :root {
      --bg-dark:   #0d1218;
      --bg-card:   #161d27;
      --bg-input:  #111820;
      --accent:    #1d7fea;
      --border:    #252f3d;
      --text-muted:#5d6e82;
      --text-body: #c8d2de;
      --text-white:#f0f4f8;
    }

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      background: var(--bg-dark);
      font-family: 'Barlow', sans-serif;
      color: var(--text-body);
      min-height: 100vh;
      display: flex;
      flex-direction: column;
    }

    /* ── NAVBAR ── */
    .hh-nav {
      background: var(--bg-dark);
      border-bottom: 1px solid var(--border);
      padding: 0.75rem 1.5rem;
      display: flex;
      align-items: center;
    }
    .brand {
      display: flex;
      align-items: center;
      gap: 0.6rem;
      text-decoration: none;
    }
    .brand-icon {
      width: 36px; height: 36px;
      background: var(--accent);
      border-radius: 9px;
      display: flex; align-items: center; justify-content: center;
      flex-shrink: 0;
    }
    .brand-name {
      font-family: 'Barlow', sans-serif;
      font-weight: 600;
      font-size: 1rem;
      color: var(--text-white);
    }

    /* ── MAIN ── */
    .hh-main {
      flex: 1;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      padding: 2.5rem 1rem;
    }

    /* ── CARD ── */
    .fp-card {
      background: var(--bg-card);
      border: 1px solid var(--border);
      border-top: 3px solid var(--accent);
      border-radius: 14px;
      padding: 2.8rem 2.4rem 2.4rem;
      width: 100%;
      max-width: 460px;
      text-align: center;
    }

    /* lock-refresh icon circle */
    .icon-wrap {
      width: 58px; height: 58px;
      background: #1a2233;
      border-radius: 50%;
      display: flex; align-items: center; justify-content: center;
      margin: 0 auto 1.8rem;
    }
    .icon-wrap i {
      font-size: 1.5rem;
      color: var(--accent);
    }

    .card-title {
      font-family: 'Barlow', sans-serif;
      font-weight: 700;
      font-size: 1.75rem;
      color: var(--text-white);
      margin-bottom: 0.7rem;
    }
    .card-sub {
      font-size: 0.88rem;
      color: var(--text-muted);
      line-height: 1.65;
      margin-bottom: 2rem;
    }

    /* ── FORM ── */
    .form-label {
      font-size: 0.88rem;
      font-weight: 500;
      color: var(--text-body);
      text-align: left;
      display: block;
      margin-bottom: 0.45rem;
    }

    .input-wrap {
      position: relative;
      margin-bottom: 1.2rem;
    }
    .input-icon {
      position: absolute;
      left: 0.95rem;
      top: 50%;
      transform: translateY(-50%);
      color: var(--text-muted);
      font-size: 1rem;
      pointer-events: none;
    }
    .hh-input {
      width: 100%;
      background: var(--bg-input);
      border: 1px solid var(--border);
      border-radius: 10px;
      color: var(--text-white);
      font-size: 0.9rem;
      padding: 0.78rem 0.9rem 0.78rem 2.6rem;
      outline: none;
      transition: border-color .2s, box-shadow .2s;
    }
    .hh-input::placeholder { color: transparent; }
    .hh-input:focus {
      border-color: var(--accent);
      box-shadow: 0 0 0 3px rgba(29,127,234,.18);
    }

    /* ── SEND OTP BUTTON ── */
    .btn-send {
      background: var(--accent);
      border: none;
      border-radius: 10px;
      color: #fff;
      font-family: 'Barlow', sans-serif;
      font-size: 1rem;
      font-weight: 600;
      padding: 0.82rem;
      width: 100%;
      transition: background .2s, transform .15s;
      cursor: pointer;
      margin-bottom: 1.6rem;
    }
    .btn-send:hover { background: #1568c9; transform: translateY(-1px); }
    .btn-send:active { transform: translateY(0); }

    /* divider */
    .divider {
      height: 1px;
      background: var(--border);
      margin-bottom: 1.3rem;
    }

    /* back to login */
    .back-link {
      font-size: 0.88rem;
      color: var(--accent);
      text-decoration: none;
      display: inline-flex;
      align-items: center;
      gap: 0.35rem;
    }
    .back-link:hover { text-decoration: underline; }

    /* ── FOOTER ── */
    .hh-footer {
      text-align: center;
      padding: 1.5rem 1rem;
      font-size: 0.82rem;
      color: var(--text-muted);
    }
    .hh-footer .foot-copy { margin-bottom: 0.4rem; }
    .hh-footer .foot-links {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 0.5rem;
    }
    .hh-footer .foot-links a {
      color: var(--text-muted);
      text-decoration: none;
      font-size: 0.82rem;
      transition: color .2s;
    }
    .hh-footer .foot-links a:hover { color: var(--text-white); }
    .hh-footer .dot { font-size: 0.4rem; vertical-align: middle; }
  </style>
</head>
<body>

  <!-- NAVBAR -->
  <nav class="hh-nav">
    <a href="#" class="brand">
      <div class="brand-icon">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="white" xmlns="http://www.w3.org/2000/svg">
          <path d="M12 2C8.5 2 5.5 4.5 5 8H4a2 2 0 0 0-2 2v1a2 2 0 0 0 2 2h.27A7 7 0 0 0 12 18a7 7 0 0 0 7.73-5H20a2 2 0 0 0 2-2v-1a2 2 0 0 0-2-2h-1C18.5 4.5 15.5 2 12 2zm0 2c2.76 0 5 2.24 5 5H7c0-2.76 2.24-5 5-5zm-7 7h14v1a5 5 0 0 1-10 0H5v-1z"/>
        </svg>
      </div>
      <span class="brand-name">Helmet Haven</span>
    </a>
  </nav>

  <!-- MAIN -->
  <main class="hh-main">
    <div class="fp-card">

      <!-- Icon -->
      <div class="icon-wrap">
        <i class="bi bi-arrow-counterclockwise" style="font-size:1.4rem; color:var(--accent);"></i>
      </div>

      <!-- Heading -->
      <h1 class="card-title">Forgot Password?</h1>
      <p class="card-sub">Enter your email address and we'll send<br>you a link to reset your password.</p>

      <!-- Form -->
      <form novalidate>
        <label class="form-label">Email Address</label>
        <div class="input-wrap">
          <i class="bi bi-envelope input-icon"></i>
          <input type="email" class="hh-input" placeholder="you@example.com"/>
        </div>

        <button type="submit" class="btn-send">Send OTP</button>
      </form>

      <!-- Divider -->
      <div class="divider"></div>

      <!-- Back to login -->
      <a href="#" class="back-link">
        <i class="bi bi-arrow-left"></i> Back to Login
      </a>

    </div>
  </main>

  <!-- FOOTER -->
  <footer class="hh-footer">
    <p class="foot-copy">© 2024 Helmet Haven. All rights reserved.</p>
    <div class="foot-links">
      <a href="#">Privacy Policy</a>
      <span class="dot">●</span>
      <a href="#">Support</a>
    </div>
  </footer>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>