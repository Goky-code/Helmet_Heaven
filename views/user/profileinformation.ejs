<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Helmet Haven - Profile Information</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet"/>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet"/>
  <style>
    :root {
      --bg-main: #0d1117;
      --bg-sidebar: #0d1117;
      --bg-card: #161b22;
      --bg-input: #0d1117;
      --border-color: #2a3240;
      --text-primary: #e6edf3;
      --text-muted: #8b949e;
      --accent-blue: #1f6feb;
      --accent-blue-hover: #388bfd;
      --sidebar-active-bg: #161b22;
      --sidebar-active-text: #1f6feb;
      --danger-color: #f85149;
    }

    * { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      background-color: var(--bg-main);
      color: var(--text-primary);
      font-family: 'Segoe UI', system-ui, sans-serif;
      font-size: 14px;
      min-height: 100vh;
      display: flex;
      flex-direction: column;
    }

    /* ── NAVBAR ── */
    .navbar-custom {
      background-color: #0d1117;
      border-bottom: 1px solid var(--border-color);
      padding: 10px 24px;
    }
    .navbar-brand-text {
      font-weight: 700;
      font-size: 18px;
      color: var(--text-primary) !important;
      display: flex;
      align-items: center;
      gap: 8px;
      text-decoration: none;
    }
    .navbar-brand-text i { color: var(--accent-blue); font-size: 20px; }
    .nav-link-custom {
      color: var(--text-primary) !important;
      font-size: 14px;
      padding: 6px 14px !important;
      text-decoration: none;
    }
    .nav-link-custom:hover { color: var(--accent-blue) !important; }

    .search-input {
      background-color: #161b22;
      border: 1px solid var(--border-color);
      color: var(--text-muted);
      border-radius: 6px;
      padding: 6px 14px 6px 36px;
      font-size: 13px;
      width: 320px;
      outline: none;
    }
    .search-input:focus { border-color: var(--accent-blue); }
    .search-input::placeholder { color: var(--text-muted); }
    .search-wrapper { position: relative; }
    .search-wrapper i {
      position: absolute;
      left: 10px;
      top: 50%;
      transform: translateY(-50%);
      color: var(--text-muted);
      font-size: 14px;
    }

    .icon-btn {
      background: #161b22;
      border: 1px solid var(--border-color);
      color: var(--text-primary);
      border-radius: 8px;
      width: 38px;
      height: 38px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 17px;
      position: relative;
      cursor: pointer;
      text-decoration: none;
    }
    .icon-btn:hover { border-color: var(--accent-blue); color: var(--accent-blue); }
    .badge-dot {
      position: absolute;
      top: -4px;
      right: -4px;
      background: var(--accent-blue);
      color: #fff;
      font-size: 9px;
      border-radius: 10px;
      padding: 1px 5px;
      font-weight: 700;
      border: 1px solid var(--bg-main);
    }

    /* ── LAYOUT ── */
    .page-wrapper {
      display: flex;
      flex: 1;
    }

    /* ── SIDEBAR ── */
    .sidebar {
      width: 260px;
      min-width: 260px;
      background: var(--bg-sidebar);
      border-right: 1px solid var(--border-color);
      padding: 28px 0;
    }
    .sidebar-heading {
      display: flex;
      align-items: center;
      gap: 10px;
      font-weight: 700;
      font-size: 15px;
      padding: 0 20px 20px;
      color: var(--text-primary);
    }
    .sidebar-heading i { color: var(--accent-blue); font-size: 18px; }

    .sidebar-item {
      display: flex;
      align-items: center;
      gap: 12px;
      padding: 11px 20px;
      color: var(--text-primary);
      text-decoration: none;
      font-size: 14px;
      cursor: pointer;
      border-left: 3px solid transparent;
      transition: background 0.15s, color 0.15s;
    }
    .sidebar-item:hover { background: var(--bg-card); color: var(--accent-blue); }
    .sidebar-item.active {
      background: var(--bg-card);
      color: var(--accent-blue);
      border-left-color: var(--accent-blue);
    }
    .sidebar-item i { font-size: 16px; width: 18px; text-align: center; }

    .sidebar-divider { border-top: 1px solid var(--border-color); margin: 12px 0; }

    .sidebar-item.logout { color: var(--danger-color); }
    .sidebar-item.logout:hover { background: rgba(248,81,73,0.08); color: var(--danger-color); }

    /* ── MAIN CONTENT ── */
    .main-content {
      flex: 1;
      padding: 36px 40px;
      background: var(--bg-main);
    }
    .page-title { font-size: 24px; font-weight: 500; color: var(--text-primary); margin-bottom: 4px; }
    .page-subtitle { color: var(--text-muted); font-size: 13px; margin-bottom: 28px; }

    /* ── CARD ── */
    .profile-card {
      background: var(--bg-card);
      border: 1px solid var(--border-color);
      border-radius: 12px;
      padding: 36px 36px 32px;
    }

    /* ── FORM ── */
    .form-label-custom {
      color: var(--text-muted);
      font-size: 13px;
      margin-bottom: 6px;
      display: block;
    }
    .form-control-custom {
      background: var(--bg-input);
      border: 1px solid var(--border-color);
      border-radius: 8px;
      color: var(--text-primary);
      font-size: 14px;
      padding: 10px 14px;
      width: 100%;
      outline: none;
      transition: border-color 0.15s;
    }
    .form-control-custom:focus { border-color: var(--accent-blue); }
    .form-control-custom::placeholder { color: #3a4455; }

    /* ── AVATAR ── */
    .avatar-wrapper {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 10px;
    }
    .avatar-circle {
      width: 110px;
      height: 110px;
      border-radius: 50%;
      background: #1c2333;
      border: 2px solid var(--border-color);
      display: flex;
      align-items: center;
      justify-content: center;
      position: relative;
    }
    .avatar-circle i { font-size: 42px; color: var(--text-muted); }
    .avatar-edit-btn {
      position: absolute;
      bottom: 4px;
      right: 4px;
      background: var(--accent-blue);
      border: 2px solid var(--bg-card);
      color: #fff;
      border-radius: 50%;
      width: 28px;
      height: 28px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 13px;
      cursor: pointer;
    }
    .avatar-hint { font-size: 11px; color: var(--text-muted); text-align: center; }
    .btn-change-photo {
      background: transparent;
      border: 1px solid var(--border-color);
      color: var(--text-primary);
      border-radius: 8px;
      font-size: 13px;
      padding: 7px 18px;
      cursor: pointer;
      transition: border-color 0.15s, color 0.15s;
    }
    .btn-change-photo:hover { border-color: var(--accent-blue); color: var(--accent-blue); }

    /* ── REFERRAL CODE ── */
    .referral-row {
      display: flex;
      align-items: center;
      gap: 0;
      border-radius: 8px;
      overflow: hidden;
      border: 1px solid var(--border-color);
      width: fit-content;
      margin-top: 10px;
    }
    .referral-code {
      background: #1c2333;
      color: var(--text-muted);
      font-size: 13px;
      padding: 8px 16px;
      letter-spacing: 0.04em;
      font-family: monospace;
      border-right: 1px solid var(--border-color);
    }
    .btn-copy {
      background: var(--accent-blue);
      color: #fff;
      border: none;
      font-size: 13px;
      font-weight: 600;
      padding: 8px 18px;
      cursor: pointer;
      letter-spacing: 0.04em;
      transition: background 0.15s;
    }
    .btn-copy:hover { background: var(--accent-blue-hover); }

    /* ── ACTION BUTTONS ── */
    .btn-save {
      background: var(--accent-blue);
      color: #fff;
      border: none;
      border-radius: 8px;
      font-size: 14px;
      font-weight: 700;
      padding: 12px 32px;
      cursor: pointer;
      transition: background 0.15s;
      letter-spacing: 0.01em;
    }
    .btn-save:hover { background: var(--accent-blue-hover); }
    .btn-cancel {
      background: transparent;
      border: none;
      color: var(--text-muted);
      font-size: 14px;
      padding: 12px 20px;
      cursor: pointer;
      transition: color 0.15s;
    }
    .btn-cancel:hover { color: var(--text-primary); }

    /* ── FOOTER ── */
    footer {
      background: var(--bg-main);
      border-top: 1px solid var(--border-color);
      padding: 40px 40px 20px;
    }
    .footer-brand { font-size: 16px; font-weight: 700; display: flex; align-items: center; gap: 8px; margin-bottom: 10px; }
    .footer-brand i { color: var(--accent-blue); }
    .footer-desc { color: var(--text-muted); font-size: 12.5px; max-width: 200px; line-height: 1.6; }
    .footer-heading { font-size: 13px; font-weight: 600; color: var(--text-primary); margin-bottom: 14px; }
    .footer-link {
      display: block;
      color: var(--text-muted);
      text-decoration: none;
      font-size: 12.5px;
      margin-bottom: 8px;
      transition: color 0.15s;
    }
    .footer-link:hover { color: var(--accent-blue); }
    .footer-input {
      background: var(--bg-input);
      border: 1px solid var(--border-color);
      border-radius: 6px 0 0 6px;
      color: var(--text-primary);
      font-size: 13px;
      padding: 8px 12px;
      outline: none;
      width: 180px;
    }
    .footer-input:focus { border-color: var(--accent-blue); }
    .footer-input::placeholder { color: var(--text-muted); }
    .btn-join {
      background: var(--accent-blue);
      color: #fff;
      border: none;
      border-radius: 0 6px 6px 0;
      padding: 8px 16px;
      font-size: 13px;
      font-weight: 600;
      cursor: pointer;
    }
    .btn-join:hover { background: var(--accent-blue-hover); }
    .footer-bottom {
      border-top: 1px solid var(--border-color);
      margin-top: 30px;
      padding-top: 16px;
      display: flex;
      justify-content: space-between;
      align-items: center;
    }
    .footer-bottom-text { color: var(--text-muted); font-size: 12px; }
    .footer-bottom-link { color: var(--text-muted); font-size: 12px; text-decoration: none; }
    .footer-bottom-link:hover { color: var(--text-primary); }
  </style>
</head>
<body>

  <!-- ── NAVBAR ── -->
  <nav class="navbar-custom d-flex align-items-center justify-content-between">
    <div class="d-flex align-items-center gap-4">
      <a class="navbar-brand-text" href="#">
        <i class="bi bi-shield-fill"></i> Helmet Haven
      </a>
      <div class="d-flex gap-1">
        <a href="#" class="nav-link-custom">Home</a>
        <a href="#" class="nav-link-custom">About Us</a>
        <a href="#" class="nav-link-custom">Contact Us</a>
      </div>
    </div>

    <div class="search-wrapper">
      <i class="bi bi-search"></i>
      <input type="text" class="search-input" placeholder="Search premium helmets..."/>
    </div>

    <div class="d-flex align-items-center gap-2">
      <a href="#" class="icon-btn">
        <i class="bi bi-cart2"></i>
        <span class="badge-dot">2</span>
      </a>
      <a href="#" class="icon-btn"><i class="bi bi-heart"></i></a>
      <a href="#" class="icon-btn"><i class="bi bi-person"></i></a>
    </div>
  </nav>

  <!-- ── PAGE BODY ── -->
  <div class="page-wrapper">

    <!-- SIDEBAR -->
    <aside class="sidebar">
      <div class="sidebar-heading">
        <i class="bi bi-person-circle"></i> My Account
      </div>

      <a href="#" class="sidebar-item active">
        <i class="bi bi-person"></i> Profile Info
      </a>
      <a href="#" class="sidebar-item">
        <i class="bi bi-bag"></i> My Orders
      </a>
      <a href="#" class="sidebar-item">
        <i class="bi bi-geo-alt"></i> Address
      </a>
      <a href="#" class="sidebar-item">
        <i class="bi bi-wallet2"></i> Wallet
      </a>
      <a href="#" class="sidebar-item">
        <i class="bi bi-scissors"></i> Coupon
      </a>
      <a href="#" class="sidebar-item">
        <i class="bi bi-lock"></i> Password Change
      </a>

      <div class="sidebar-divider"></div>

      <a href="" class="sidebar-item logout">
        <i class="bi bi-box-arrow-right"></i> Logout
      </a>
    </aside>

    <!-- MAIN -->
    <main class="main-content">
      <h1 class="page-title">Profile Information</h1>
      <p class="page-subtitle">Manage your personal details and account settings.</p>
   <form action="/user/profile" method="POST" enctype="multipart/form-data">
      <div class="profile-card">
        <div class="row g-4">

          <!-- LEFT: Form Fields -->
          <div class="col-lg-8">
            <div class="row g-3 mb-3">
              <div class="col-6">
                <label class="form-label-custom">First Name</label>
           <input type="text" name="firstname" class="form-control-custom"
              value="<%= user.name ? user.name.split(' ')[0] : '' %>">
              </div>
              <div class="col-6">
                <label class="form-label-custom">Last Name</label>
               <input type="text" name="lastname" class="form-control-custom"
                   value="<%= user.name ? user.name.split(' ')[1] : '' %>">
              </div>
            </div>

            <div class="mb-3">
              <label class="form-label-custom">Email Address</label>
              <input type="email" name="email" class="form-control-custom"
                   value="<%= user.email %>">
            </div>

            <div class="mb-3">
              <label class="form-label-custom">Phone Number</label>
              <input type="tel" name="phone" class="form-control-custom"
                 value="<%= user.phone || '' %>">
            </div>
          </div>

          <!-- RIGHT: Avatar -->
          <div class="col-lg-4 d-flex flex-column align-items-center justify-content-start pt-1">
            <div class="avatar-wrapper">

  
  <input type="file" name="profileImage" id="fileInput" hidden>

  <div class="avatar-circle">
    <% if (user.profileImage) { %>
      <img src="<%= user.profileImage %>" 
           style="width:100%; height:100%; border-radius:50%; object-fit:cover;">
    <% } else { %>
      <i class="bi bi-person"></i>
    <% } %>

    <div class="avatar-edit-btn"
         onclick="document.getElementById('fileInput').click()">
      <i class="bi bi-pencil-fill"></i>
    </div>
  </div>

  <p class="avatar-hint">JPG, PNG or GIF. Max size 2MB.</p>

 
  <button type="button" class="btn-change-photo"
    onclick="document.getElementById('fileInput').click()">
    Change Photo
  </button>
              <div class="referral-row mt-2">
                <span class="referral-code">X9-WANGER-HEAVEN</span>
                <button class="btn-copy" onclick="navigator.clipboard.writeText('X9-WANGER-HEAVEN')">COPY</button>
              </div>
            </div>
          </div>

        </div>

        <!-- Action Buttons -->
        <div class="d-flex align-items-center gap-2 mt-4 pt-2">
          <button class="btn-save">Save Changes</button>
          <button class="btn-cancel">Cancel</button>
        </div>
      </div>
    </main>
  </div>
</form>
  <!-- ── FOOTER ── -->
  <footer>
    <div class="row g-4">
      <div class="col-lg-3">
        <div class="footer-brand">
          <i class="bi bi-shield-fill"></i> Helmet Haven
        </div>
        <p class="footer-desc">The world's premier destination for high-end safety and performance headgear. Trusted by professionals, loved by enthusiasts.</p>
      </div>

      <div class="col-lg-2 offset-lg-1">
        <p class="footer-heading">Shop</p>
        <a href="#" class="footer-link">Full Face</a>
        <a href="#" class="footer-link">Off-Road</a>
        <a href="#" class="footer-link">Modular</a>
        <a href="#" class="footer-link">Accessories</a>
      </div>

      <div class="col-lg-2">
        <p class="footer-heading">Support</p>
        <a href="#" class="footer-link">Shipping Policy</a>
        <a href="#" class="footer-link">Return &amp; Exchange</a>
        <a href="#" class="footer-link">Size Guide</a>
        <a href="#" class="footer-link">FAQ</a>
      </div>

      <div class="col-lg-3">
        <p class="footer-heading">Newsletter</p>
        <p class="footer-desc mb-3">Get early access to drops and exclusive offers.</p>
        <div class="d-flex">
          <input type="email" class="footer-input" placeholder="Email address"/>
          <button class="btn-join">Join</button>
        </div>
      </div>
    </div>

    <div class="footer-bottom">
      <span class="footer-bottom-text">© 2024 Helmet Haven. All rights reserved.</span>
      <div class="d-flex gap-3">
        <a href="#" class="footer-bottom-link">Privacy Policy</a>
        <a href="#" class="footer-bottom-link">Terms of Service</a>
      </div>
    </div>
  </footer>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>