<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Login | Helmet Haven</title>
    
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">

    <style>
        /* CSS STYLES */
        body, html {
            height: 100%;
            margin: 0;
            font-family: 'Inter', sans-serif;
            background-color: #0b1119; /* Match image background */
            color: white;
            overflow-x: hidden;
        }

        /* Left Side Image */
        .hero-side {
            background: linear-gradient(rgba(0,0,0,0.2), rgba(0,0,0,0.6)), 
                        url("/user/login.png");
            background-size: cover;
            background-position: center;
            height: 100vh;
        }

        .overlay {
            height: 100%;
            display: flex;
            flex-direction: column;
            justify-content: flex-end;
            padding-bottom: 80px;
        }

        .brand-logo {
            color: #1a73e8;
            font-weight: 700;
            font-size: 1.2rem;
            display: flex;
            align-items: center;
            gap: 10px;
            margin-bottom: 2rem;
        }

        /* Right Side Form */
        .login-side {
            background-color: #0b1119;
            height: 100vh;
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
        }

        .form-container {
            max-width: 420px;
            width: 100%;
        }

        /* Input Styling */
        .input-group-text {
            background-color: transparent !important;
            border: 1px solid #2c343f !important;
            color: #6c757d !important;
        }

        .form-control {
            background-color: transparent !important;
            border: 1px solid #2c343f !important;
            color: white !important;
            padding: 12px;
        }

        .form-control::placeholder {
            color: #495057;
        }

        .form-control:focus {
            box-shadow: none;
            border-color: #1a73e8 !important;
        }

        .form-label {
            font-size: 0.75rem;
            letter-spacing: 1px;
            color: #6c757d;
        }

        /* Buttons and Links */
        .btn-primary {
            background-color: #1a73e8;
            border: none;
            padding: 12px;
            font-weight: 600;
        }

        .btn-outline-secondary {
            border-color: #2c343f;
            color: white;
            padding: 12px;
        }

        .blue-text {
            color: #1a73e8;
            text-decoration: none;
        }

        /* Divider */
        .divider {
            display: flex;
            align-items: center;
            text-align: center;
            color: #495057;
            font-size: 0.8rem;
            margin: 30px 0;
        }

        .divider::before, .divider::after {
            content: '';
            flex: 1;
            border-bottom: 1px solid #2c343f;
        }

        .divider:not(:empty)::before { margin-right: .5em; }
        .divider:not(:empty)::after { margin-left: .5em; }

        /* Footer Links */
        .footer-links {
            margin-top: auto;
            padding-bottom: 30px;
            font-size: 10px;
            letter-spacing: 1px;
            color: #495057;
        }

        .footer-links a {
            color: #495057;
            text-decoration: none;
            margin: 0 10px;
        }

        /* Mobile View Adjustment */
        @media (max-width: 991px) {
            .hero-side { display: none; }
            .login-side { height: auto; min-height: 100vh; padding: 40px 20px; }
        }
    </style>
</head>
<body>

    <div class="container-fluid p-0">
        <div class="row g-0">
            
            <div class="col-lg-6 hero-side d-none d-lg-block">
                <div class="overlay px-5">
                    <div class="brand-logo">
                        <i class="bi bi-shield-shaded" style="font-size: 1.5rem;"></i> HELMET HAVEN
                    </div>
                    <h1 class="display-4 fw-bold mb-3">The ultimate guard<br>for your journey.</h1>
                    <p class="text-secondary mb-0" style="max-width: 450px;">Join the community of elite riders choosing premium protection without compromising on style.</p>
                </div>
            </div>

            <div class="col-lg-6 login-side">
                <div class="form-container px-4">
                    <h2 class="fw-bold mb-2">Welcome Back</h2>
                    <p class="text-muted mb-5">Enter your credentials to access your account</p>

                    <form action="/auth/login" method="POST">
    
    <% if (typeof message != 'undefined') { %>
        <div class="alert alert-danger py-2 small"><%= message %></div>
    <% } %>
                        <div class="mb-4">
                            <label class="form-label fw-bold">EMAIL ADDRESS</label>
                            <div class="input-group">
                                <span class="input-group-text"><i class="bi bi-envelope"></i></span>
                                <input type="email" class="form-control" placeholder="Enter your email">
                            </div>
                        </div>

                        <div class="mb-4">
                            <div class="d-flex justify-content-between">
                                <label class="form-label fw-bold">PASSWORD</label>
                                <a href="" class="blue-text small">Forgot Password?</a>
                            </div>
                            <div class="input-group">
                                <span class="input-group-text"><i class="bi bi-lock"></i></span>
                                <input type="password" class="form-control" placeholder="••••••••">
                            </div>
                        </div>

                        <button type="submit" class="btn btn-primary w-100 d-flex justify-content-center align-items-center gap-2">
                            Log In <i class="bi bi-box-arrow-in-right"></i>
                        </button>

                        <div class="divider">Or continue with</div>

                       <a href="/auth/google" class="btn btn-outline-secondary w-100 d-flex justify-content-center align-items-center gap-2">
        <i class="bi bi-google"></i> Google
    </a>
                        <p class="text-center mt-4 text-muted small">
                            New to Helmet Haven? <a href="#" class="blue-text fw-bold">Create an account</a>
                        </p>
                    </form>
                </div>

                <div class="footer-links">
                    <a href="#">PRIVACY POLICY</a>
                    <a href="#">TERMS OF SERVICE</a>
                    <a href="#">CONTACT SUPPORT</a>
                </div>
            </div>

        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>