<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Helmet Haven | Safety Redefined</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">

    <style>
        :root {
            --bg-dark: #070b11;
            --card-bg: #111821;
            --accent-blue: #007bff;
            --text-gray: #8b949e;
            --border-color: #21262d;
        }

        body {
            background-color: var(--bg-dark);
            color: white;
            font-family: 'Plus Jakarta Sans', sans-serif;
            overflow-x: hidden;
        }

        /* Navbar */
        .navbar {
            background-color: var(--bg-dark);
            padding: 15px 5%;
            border-bottom: 1px solid var(--border-color);
        }
        .nav-link { color: var(--text-gray) !important; font-size: 0.9rem; margin: 0 10px; }
        .nav-link:hover { color: white !important; }
        .search-bar {
            background: #1c2128;
            border: none;
            border-radius: 8px;
            color: white;
            padding: 8px 15px;
            width: 250px;
            font-size: 0.8rem;
        }

        /* Hero Section */
        .hero-section { padding: 80px 5%; }
        .hero-title { font-size: clamp(2.5rem, 5vw, 4.5rem); font-weight: 800; line-height: 1.1; }
        .hero-tagline { color: var(--accent-blue); font-weight: 700; text-transform: uppercase; font-size: 0.75rem; letter-spacing: 2px; }
        .btn-blue { background: var(--accent-blue); border: none; padding: 12px 25px; font-weight: 600; color: white; border-radius: 8px; }
        .btn-outline { background: transparent; border: 1px solid var(--border-color); color: white; padding: 12px 25px; border-radius: 8px; }
        
        /* Features */
        .feature-card {
            background: var(--card-bg);
            border: 1px solid var(--border-color);
            padding: 30px;
            border-radius: 12px;
            height: 100%;
        }
        .feature-icon {
            width: 45px;
            height: 45px;
            background: rgba(0, 123, 255, 0.1);
            border-radius: 8px;
            display: flex;
            align-items: center;
            justify-content: center;
            color: var(--accent-blue);
            margin-bottom: 20px;
        }

        /* Summer Sale Banner */
        .sale-banner {
            background: linear-gradient(90deg, #0062ff, #00a2ff);
            border-radius: 15px;
            padding: 50px;
            margin: 40px 5%;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }
        .btn-white { background: white; color: var(--accent-blue); font-weight: 700; border: none; padding: 10px 25px; border-radius: 8px; }

        /* Product Cards */
        .product-img-box {
            background: #161b22;
            border-radius: 12px;
            padding: 30px;
            margin-bottom: 15px;
            position: relative;
            transition: 0.3s;
        }
        .product-img-box:hover { transform: translateY(-5px); }
        .badge-sale {
            position: absolute;
            top: 15px;
            left: 15px;
            background: var(--accent-blue);
            font-size: 0.65rem;
            padding: 4px 10px;
            border-radius: 4px;
            font-weight: 700;
        }
        .price-current { font-weight: 700; color: #fff; }
        .price-old { font-size: 0.8rem; text-decoration: line-through; color: var(--text-gray); margin-left: 8px; }

        /* Footer */
        footer { border-top: 1px solid var(--border-color); padding: 60px 5% 30px; margin-top: 80px; }
        .footer-link-list { list-style: none; padding: 0; color: var(--text-gray); font-size: 0.85rem; }
        .footer-link-list li { margin-bottom: 10px; cursor: pointer; }
        .footer-link-list li:hover { color: white; }

        @media (max-width: 768px) {
            .sale-banner { flex-direction: column; text-align: center; gap: 20px; }
            .hero-title { font-size: 2.8rem; }
        }
    </style>
</head>
<body>

    <nav class="navbar navbar-expand-lg sticky-top">
        <div class="container-fluid p-0">
            <a class="navbar-brand fw-bold text-white" href="#"><i class="bi bi-shield-shaded text-primary me-2"></i>HELMET HAVEN</a>
            <div class="collapse navbar-collapse justify-content-center">
                <ul class="navbar-nav">
                    <li class="nav-item"><a class="nav-link" href="#">Home</a></li>
                    <li class="nav-item"><a class="nav-link" href="#">About Us</a></li>
                    <li class="nav-item"><a class="nav-link" href="#">Contact Us</a></li>
                </ul>
                <input type="text" class="search-bar ms-lg-3" placeholder="Search premium helmets...">
            </div>
            <div class="d-flex align-items-center gap-3">
                <i class="bi bi-cart3 position-relative"><span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-primary" style="font-size: 0.5rem;">2</span></i>
                <i class="bi bi-person"></i>
                <i class="bi bi-heart"></i>
            </div>
        </div>
    </nav>

    <section class="hero-section">
        <div class="row align-items-center">
            <div class="col-lg-6">
                <span class="hero-tagline">Premium Protection</span>
                <h1 class="hero-title mt-3 mb-4">Safety<br>Redefined</h1>
                <p class="text-secondary mb-5" style="max-width: 480px;">Experience the pinnacle of protection with our premium, high-end motorcycle helmets designed for the modern rider. Purity in design, excellence in safety.</p>
                <div class="d-flex gap-3">
                    <button class="btn-blue">Explore Collection</button>
                    <button class="btn-outline">Our Technology</button>
                </div>
            </div>
            <div class="col-lg-6 text-center mt-5 mt-lg-0">
                <img src="/user/Image.png" alt="White Helmet" class="img-fluid" style="max-height: 500px; filter: drop-shadow(0 20px 50px rgba(0,0,0,0.5));">
            </div>
        </div>
    </section>

    <section class="container-fluid px-5 pb-5">
        <h2 class="fw-bold mb-1">Why Us</h2>
        <p class="text-secondary mb-5">Our commitment to safety and innovation is reflected in every detail.</p>
        <div class="row g-4">
            <div class="col-md-4">
                <div class="feature-card">
                    <div class="feature-icon"><i class="bi bi-shield-lock"></i></div>
                    <h5 class="fw-bold">Impact Protection</h5>
                    <p class="text-secondary small">Advanced multi-density EPS liners for maximum energy absorption in all conditions.</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="feature-card">
                    <div class="feature-icon"><i class="bi bi-wind"></i></div>
                    <h5 class="fw-bold">Aerodynamic Design</h5>
                    <p class="text-secondary small">Wind-tunnel tested shapes for perfect stability at high speeds and reduced wind noise.</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="feature-card">
                    <div class="feature-icon"><i class="bi bi-airplane"></i></div>
                    <h5 class="fw-bold">Ultra Lightweight</h5>
                    <p class="text-secondary small">Carbon fiber and aerospace composites used to reduce neck fatigue during long rides.</p>
                </div>
            </div>
        </div>
    </section>

    <section class="sale-banner">
        <div>
            <span class="badge bg-white text-primary rounded-pill px-3 py-1 fw-bold" style="font-size: 0.6rem;">LIMITED TIME OFFER</span>
            <h2 class="display-4 fw-bold mt-3 mb-0">Summer Blast Sale</h2>
            <p class="mb-0">Gear up for the season with our biggest discount yet.</p>
        </div>
        <div class="text-center">
            <h2 class="display-3 fw-bold">Up to 40% <small class="fs-4">OFF</small></h2>
            <button class="btn-white mt-2">Shop the Sale</button>
        </div>
    </section>

    <section class="container-fluid px-5 py-5">
        <div class="d-flex justify-content-between align-items-end mb-4">
            <div>
                <h2 class="fw-bold">Trending Now</h2>
                <p class="text-secondary small">The most sought-after safety equipment of the season.</p>
            </div>
            <a href="#" class="text-primary text-decoration-none fw-bold small">View All <i class="bi bi-arrow-right"></i></a>
        </div>
        <div class="row g-4">
            <div class="col-md-3">
                <div class="product-img-box">
                    <span class="badge-sale">20% OFF</span>
                    <img src="/user/Image1.png" class="img-fluid" alt="Aura White">
                </div>
                <h6 class="mb-1 fw-bold">Aura Carbon White</h6>
                <p class="text-secondary small mb-2">Ultra-light carbon fiber shell</p>
                <div class="price-current">$479.20 <span class="price-old">$599.00</span></div>
            </div>
            <div class="col-md-3">
                <div class="product-img-box">
                    <span class="badge-sale">15% OFF</span>
                    <img src="/user/Image 2.png" class="img-fluid" style="filter: hue-rotate(150deg);" alt="Nebula Gloss">
                </div>
                <h6 class="mb-1 fw-bold">Nebula Gloss</h6>
                <p class="text-secondary small mb-2">Anti-fog dual visor included</p>
                <div class="price-current">$382.50 <span class="price-old">$450.00</span></div>
            </div>
            <div class="col-md-3">
                <div class="product-img-box">
                    <img src="/user/Image3.png" class="img-fluid" alt="Phantom Matte">
                </div>
                <h6 class="mb-1 fw-bold">Phantom Matte</h6>
                <p class="text-secondary small mb-2">Reinforced aerodynamic shell</p>
                <div class="price-current">$480.00</div>
            </div>
            <div class="col-md-3">
                <div class="product-img-box">
                    <span class="badge-sale">30% OFF</span>
                    <img src="/user/Image4.png" class="img-fluid" alt="Apex Racer">
                </div>
                <h6 class="mb-1 fw-bold">Apex Racer</h6>
                <p class="text-secondary small mb-2">Professional racing specification</p>
                <div class="price-current">$434.00 <span class="price-old">$620.00</span></div>
            </div>
        </div>
    </section>

    <footer>
        <div class="row">
            <div class="col-lg-4 mb-4">
                <div class="fw-bold mb-3"><i class="bi bi-shield-shaded text-primary me-2"></i>HELMET HAVEN</div>
                <p class="text-secondary small">Designing the future of rider safety with uncompromising style and technology since 2012.</p>
            </div>
            <div class="col-6 col-lg-2 mb-4">
                <h6 class="fw-bold mb-3 small">Shop</h6>
                <ul class="footer-link-list">
                    <li>Street Helmets</li>
                    <li>Racing Series</li>
                    <li>Accessories</li>
                </ul>
            </div>
            <div class="col-6 col-lg-2 mb-4">
                <h6 class="fw-bold mb-3 small">Company</h6>
                <ul class="footer-link-list">
                    <li>About Us</li>
                    <li>Technology</li>
                    <li>Safety Standards</li>
                </ul>
            </div>
            <div class="col-lg-4 mb-4">
                <h6 class="fw-bold mb-3 small">Newsletter</h6>
                <p class="text-secondary small">Join for updates and early access.</p>
                <div class="input-group">
                    <input type="text" class="form-control bg-dark border-secondary text-white small" placeholder="Email address">
                    <button class="btn btn-primary"><i class="bi bi-send"></i></button>
                </div>
            </div>
        </div>
        <div class="d-flex justify-content-between align-items-center mt-5 pt-3 border-top border-secondary">
            <p class="text-secondary xsmall mb-0" style="font-size: 0.7rem;">&copy; 2026 Helmet Haven. All rights reserved.</p>
            <div class="d-flex gap-3 text-secondary">
                <i class="bi bi-globe"></i>
                <i class="bi bi-instagram"></i>
                <i class="bi bi-twitter-x"></i>
            </div>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>